# Copy to `rn/.env` for local dev.
# For EAS builds, set these as EAS Secrets (recommended) instead of committing real values.

# Supabase (cloud sync)
EXPO_PUBLIC_SUPABASE_URL=YOUR_PROJECT_URL
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Spotify (optional)
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID
